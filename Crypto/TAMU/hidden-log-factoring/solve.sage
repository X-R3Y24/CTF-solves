h = power_mod(g, (p-1) // 2^101, p)
a = power_mod(A, (p-1) // 2^101, p)
s = discrete_log(a, Mod(h, p), ord=2^101)

print(s)
mask = hkdf_mask(long_to_bytes(int(s)), D.bit_length() // 8)
d = D ^^ bytes_to_long(mask)

k = int(d * e - 1)
from random import randrange
while True:
    g = randrange(2, int(n))
    t = k
    while t % 2 == 0:
        t //= 2
    x = pow(g, t, int(n))
    while x != 1:
        y = pow(x, 2, int(n))
        if y == 1:
            p = gcd(x - 1, int(n))
            if 1 < p < int(n):
                q1 = p
                q2 = int(n) // p
                print(q1 * q2 == int(n))
                break
        x = y
    else:
        continue
    break
  
r1 = Mod(c, q1).sqrt()
r2 = Mod(c, q2).sqrt()

for s1 in [r1, -r1]:
    for s2 in [r2, -r2]:
        x = crt([int(s1), int(s2)], [int(q1), int(q2)])
        candidate = long_to_bytes(int(x))
        if b'gigem' in candidate:
            print(candidate.decode())
            
